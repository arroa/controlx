# MongoDB (local o Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/controlx
MONGODB_DB_NAME=controlx

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Desarrollo local — omite Clerk y permite login sin OTP (nunca en producción)
CONTROLX_DEV_BYPASS=false
DEV_SESSION_SECRET=
SUPER_ADMIN_EMAIL=la.carrasco@gmail.com

# Mock: combo en el header para “actuar como” un actor del mapa (SuperAdmin / bypass)
CONTROLX_DEV_ACTOR_IMPERSONATION=false

# Bootstrap super admin en Clerk (una vez):
# npm run setup:admin

# Vercel Blob — evidencias (imagen/PDF) en ejecución
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=
